# Server
PORT=3001
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# eBay
EBAY_APP_ID=your-app-id
EBAY_DEV_ID=your-dev-id
EBAY_CERT_ID=your-cert-id
EBAY_REDIRECT_URI=your-redirect-uri
EBAY_SITE_ID=2
EBAY_ENVIRONMENT=sandbox
EBAY_LOCATION=Vancouver, BC
EBAY_POSTAL_CODE=V5V1A1
EBAY_MOCK_MODE=true

# eBay listing location (required for publishing)
# At least one of EBAY_LOCATION or EBAY_POSTAL_CODE must be set.
EBAY_LOCATION=Vancouver, BC
EBAY_POSTAL_CODE=V6B1A1

# Anthropic (Claude Vision)
ANTHROPIC_API_KEY=your-anthropic-key

# PriceCharting
PRICECHARTING_API_KEY=your-pricecharting-key

# Storage (S3 or Cloudinary)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Redis (Bull queue) — leave empty to run publish jobs synchronously
REDIS_URL=redis://localhost:6379

# SendGrid
SENDGRID_API_KEY=your-sendgrid-key
SENDGRID_FROM_EMAIL=noreply@snapcard.ca

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173

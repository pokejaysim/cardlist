# Server
PORT=3001
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# eBay API
EBAY_APP_ID=your-app-id
EBAY_DEV_ID=your-dev-id
EBAY_CERT_ID=your-cert-id
EBAY_SITE_ID=2
EBAY_OAUTH_CLIENT_ID=your-oauth-client-id
EBAY_OAUTH_CLIENT_SECRET=your-oauth-client-secret
EBAY_OAUTH_REDIRECT_URI=http://localhost:3001/api/auth/ebay-callback

# PriceCharting
PRICECHARTING_API_KEY=your-api-key

# Redis (for Bull queue)
REDIS_URL=redis://localhost:6379

# Frontend URL (for CORS + OAuth redirect)
FRONTEND_URL=http://localhost:5173
